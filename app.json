{
  "expo": {
    "name": "NextLook",
    "slug": "nextlook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nextlook.app",
      "infoPlist": {
        "NSCameraUsageDescription": "옷을 촬영해 옷장에 등록하려면 카메라 접근이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "갤러리에서 옷 사진을 불러오려면 사진 접근이 필요합니다.",
        "NSLocationWhenInUseUsageDescription": "내일 날씨에 맞춘 추천을 위해 위치가 필요합니다."
      }
    },
    "android": {
      "package": "com.nextlook.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A1A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "NextLook",
      "shortName": "NextLook",
      "lang": "ko",
      "themeColor": "#1B6B4A",
      "backgroundColor": "#FAFAF8",
      "display": "standalone",
      "orientation": "portrait",
      "description": "AI가 추천하는 오늘의 코디"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "옷을 촬영해 옷장에 등록하려면 카메라 접근이 필요합니다."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "갤러리에서 옷 사진을 불러오려면 사진 접근이 필요합니다.",
          "cameraPermission": "옷을 촬영해 옷장에 등록하려면 카메라 접근이 필요합니다."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "내일 날씨에 맞춘 추천을 위해 위치가 필요합니다."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "4c593158-fa50-4eb8-a282-362ed59df2f3"
      }
    },
    "owner": "seojinyu"
  }
}
